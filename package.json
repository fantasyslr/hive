{
  "name": "hive",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "tsx packages/hive-gw/src/index.ts",
    "dev": "tsx watch packages/hive-gw/src/index.ts",
    "build": "tsup packages/hive-gw/src/index.ts --format esm --dts",
    "test": "vitest run",
    "setup": "bash scripts/setup.sh",
    "smoke": "bash scripts/smoke-test.sh",
    "discover-mem": "tsx scripts/discover-mem-tools.ts",
    "stress-test-mem": "tsx scripts/stress-test-mem.ts"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
